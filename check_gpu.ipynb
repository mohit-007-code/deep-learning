   "source": [
    "import tensorflow as tf\n",
    "\n",
    "print(\"TensorFlow version:\", tf.__version__)\n",
    "\n",
    "# Check available GPUs\n",
    "gpus = tf.config.list_physical_devices('GPU')\n",
    "\n",
    "if gpus:\n",
    "    print(\"✅ GPU is available!\")\n",
    "    print(\"GPUs:\", gpus)\n",
    "else:\n",
    "    print(\"❌ No GPU found. Using CPU instead.\")"
   ]
